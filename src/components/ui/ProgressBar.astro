<div id="progress-bar" class="progress-bar"></div>

<script>
const progressBar = document.getElementById('progress-bar');

if (progressBar instanceof HTMLDivElement && !progressBar.dataset.initialized) {
  const progressBarElement = progressBar;

  progressBarElement.dataset.initialized = 'true';

  let maxScroll = 0;
  let frame = 0;

  function recalculateMaxScroll() {
    maxScroll = Math.max(document.documentElement.scrollHeight - window.innerHeight, 0);
  }

  function renderProgress() {
    frame = 0;
    const progress = maxScroll > 0 ? Math.min(window.scrollY / maxScroll, 1) : 0;
    progressBarElement.style.transform = `scaleX(${progress})`;
  }

  function requestRender() {
    if (frame)
      return;

    frame = window.requestAnimationFrame(renderProgress);
  }

  function syncProgress() {
    recalculateMaxScroll();
    requestRender();
  }

  document.addEventListener('astro:page-load', syncProgress);
  window.addEventListener('scroll', requestRender, { passive: true });
  window.addEventListener('resize', syncProgress, { passive: true });

  syncProgress();
}
</script>

<style>
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    background: linear-gradient(to right, var(--brand-red), var(--brand-orange));
    width: 100%;
    z-index: 999999;
    transform: scaleX(0);
    transform-origin: left center;
    will-change: transform;
  }
</style>
