---
import { Icon } from 'astro-icon/components';

type Props = {
  title: string;
  icon: string;
};

const { title, icon } = Astro.props;
---
<div class="feature-card">
  <div class="card-header">
    <div class="icon-wrapper">
      <Icon name={`heroicons:${icon}`} class="card-icon" />
    </div>
    <h3>{title}</h3>
  </div>
  <div class="card-content">
    <slot />
  </div>
</div>

<style>
  .feature-card {
    background-color: transparent;
    border: 1px solid #BFC1B7;
    border-bottom: 3px solid #BFC1B7;
    border-radius: 8px;
    padding: 1.5rem;
    color: #4D4F46;
    transition:
      transform 0.15s ease,
      border-bottom-color 0.15s ease,
      background-color 0.15s ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    border-bottom-color: #EB9D2A;
    background-color: #FDFDF8;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .icon-wrapper {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: rgba(245, 78, 0, 0.1);
    border-radius: 8px;
  }

  .card-icon {
    color: #F54E00;
    width: 24px;
    height: 24px;
  }

  h3 {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    font-family: 'IBM Plex Sans', 'Noto Sans Thai', system-ui, sans-serif;
    color: #23251D;
  }

  .card-content {
    line-height: 1.6;
    color: #65675E;
  }

  .card-content :global(a) {
    color: #F54E00;
    text-decoration: underline;
  }

  .card-content :global(a:hover) {
    color: #EB9D2A;
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card {
      transition: none;
    }
  }
</style>
