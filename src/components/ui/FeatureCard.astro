---
import { Icon } from 'astro-icon/components';

type Props = {
  title: string;
  icon: string;
};

const { title, icon } = Astro.props;
---
<div class="feature-card">
  <div class="card-header">
    <div class="icon-wrapper">
      <Icon name={`heroicons:${icon}`} class="card-icon" />
    </div>
    <h3>{title}</h3>
  </div>
  <div class="card-content">
    <slot />
  </div>
</div>

<style>
  .feature-card {
    background-color: transparent;
    border: 1px solid var(--border-default);
    border-bottom: var(--depth-border) solid var(--border-default);
    border-radius: var(--radius-sm);
    padding: 1.5rem;
    color: var(--text-primary);
    transition:
      transform var(--duration-150) var(--ease),
      border-bottom-color var(--duration-150) var(--ease),
      background-color var(--duration-150) var(--ease);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    border-bottom-color: var(--brand-orange);
    background-color: var(--surface-page);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .icon-wrapper {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: color-mix(in srgb, var(--brand-red) 10%, transparent);
    border-radius: var(--radius-sm);
  }

  .card-icon {
    color: var(--brand-red);
    width: 24px;
    height: 24px;
  }

  h3 {
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    font-family: var(--font-sans);
    color: var(--text-heading);
  }

  .card-content {
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .card-content :global(a) {
    color: var(--brand-red);
    text-decoration: underline;
  }

  .card-content :global(a:hover) {
    color: var(--brand-orange);
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card { transition: none; }
  }
</style>
