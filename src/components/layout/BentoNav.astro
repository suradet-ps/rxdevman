---
const navItems = [
  { href: '/', label: 'Home', icon: 'home', span: 2 },
  { href: '/blog', label: 'Blog', icon: 'blog', span: 1 },
  { href: '/tools', label: 'Tools', icon: 'tools', span: 1 },
  { href: '/hosxp', label: 'HOSxP', icon: 'hosxp', span: 2 },
  { href: '/invs', label: 'INVS', icon: 'invs', span: 1 },
  { href: '/about', label: 'About', icon: 'about', span: 1 },
];

const pathname = Astro.url.pathname;
---

<div class="bento-shell" id="bento-shell">
  <!-- Mobile top bar (logo + hamburger) -->
  <div class="bento-topbar">
    <a href="/" class="bento-logo" aria-label="rxdevman Homepage">
      <svg class="bento-logo-svg" width="28" height="28" viewBox="0 0 200 200" aria-hidden="true">
        <path d="M40 30 V170 M40 30 H110 C145 30 160 55 160 80 C160 110 140 125 110 125 H40 M110 125 L160 170" fill="none" stroke="#F54E00" stroke-width="18" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M85 65 L115 95 M115 65 L85 95" fill="none" stroke="#F54E00" stroke-width="15" stroke-linecap="round" />
      </svg>
      <span class="bento-logo-text"><span class="logo-rx">rx</span><span class="logo-devman">devman</span></span>
    </a>
    <button class="bento-hamburger" id="bento-hamburger" aria-label="Toggle navigation" aria-expanded="false" aria-controls="bento-overlay">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>

  <!-- Desktop bento nav -->
  <nav class="bento-panel" aria-label="Main navigation">
    <div class="bento-grid">
      {navItems.map(({ href, label, icon, span }) => {
        const isActive = href === '/' ? pathname === '/' : pathname.startsWith(href);
        return (
          <a
            href={href}
            class:list={['bento-tile', `bento-tile--${icon}`, { 'active': isActive, 'col-span-2': span === 2 }]}
          >
            <span class="bento-tile-icon">
              {
                icon === 'home' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                )
              }
              {
                icon === 'blog' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                )
              }
              {
                icon === 'tools' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" /></svg>
                )
              }
              {
                icon === 'hosxp' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2" /></svg>
                )
              }
              {
                icon === 'invs' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" /><rect x="8" y="2" width="8" height="4" rx="1" ry="1" /></svg>
                )
              }
              {
                icon === 'about' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                )
              }
            </span>
            <span class="bento-tile-label">{label}</span>
          </a>
        );
      })}
    </div>
  </nav>
</div>

<!-- Mobile overlay -->
<div class="bento-overlay" id="bento-overlay" aria-hidden="true">
  <nav class="bento-overlay-nav" aria-label="Mobile navigation">
    <div class="bento-grid">
      {navItems.map(({ href, label, icon, span }) => {
        const isActive = href === '/' ? pathname === '/' : pathname.startsWith(href);
        return (
          <a
            href={href}
            class:list={['bento-tile', `bento-tile--${icon}`, { 'active': isActive, 'col-span-2': span === 2 }]}
          >
            <span class="bento-tile-icon">
              {
                icon === 'home' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                )
              }
              {
                icon === 'blog' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                )
              }
              {
                icon === 'tools' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" /></svg>
                )
              }
              {
                icon === 'hosxp' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2" /></svg>
                )
              }
              {
                icon === 'invs' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" /><rect x="8" y="2" width="8" height="4" rx="1" ry="1" /></svg>
                )
              }
              {
                icon === 'about' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                )
              }
            </span>
            <span class="bento-tile-label">{label}</span>
          </a>
        );
      })}
    </div>
  </nav>
</div>

<script>
  const hamburger = document.getElementById('bento-hamburger');
  const overlay = document.getElementById('bento-overlay');

  function openMenu() {
    overlay?.classList.add('open');
    hamburger?.classList.add('active');
    hamburger?.setAttribute('aria-expanded', 'true');
    overlay?.setAttribute('aria-hidden', 'false');
    document.body.classList.add('no-scroll');
  }

  function closeMenu() {
    overlay?.classList.remove('open');
    hamburger?.classList.remove('active');
    hamburger?.setAttribute('aria-expanded', 'false');
    overlay?.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('no-scroll');
  }

  hamburger?.addEventListener('click', () => {
    overlay?.classList.contains('open') ? closeMenu() : openMenu();
  });

  overlay?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
</script>

<style>
  /* ── Design tokens ── */
  .bento-shell {
    --bento-gap: 0.5rem;
    --bento-radius: 12px;
    --bento-bg: #e5e7e0;
    --bento-border: #bfc1b7;
    --bento-text: #4d4f46;
    --bento-red: #f54e00;
    --bento-orange: #eb9d2a;
    --bento-active-bg: #ffffff;
  }

  /* ── Mobile top bar (shown only on small screens) ── */
  .bento-topbar {
    display: none;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: 56px;
    background: var(--bento-bg);
    border-bottom: 1px solid var(--bento-border);
    z-index: 999998;
  }

  .bento-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .bento-logo-svg {
    width: 28px;
    height: 28px;
    transition: transform 0.3s ease;
  }

  .bento-logo:hover .bento-logo-svg {
    transform: rotate(-12deg) scale(1.08);
  }

  .bento-logo-text {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .bento-logo-text .logo-rx { color: var(--bento-red); }
  .bento-logo-text .logo-devman { color: var(--bento-text); }

  .bento-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--bento-border);
    border-radius: 6px;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: background 0.15s ease;
  }

  .bento-hamburger:hover { background: rgba(0,0,0,0.06); }

  .bento-hamburger .bar {
    width: 15px;
    height: 2px;
    background: var(--bento-text);
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.28s ease, opacity 0.28s ease;
  }

  .bento-hamburger.active .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .bento-hamburger.active .bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .bento-hamburger.active .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Desktop bento panel ── */
  .bento-panel {
    position: sticky;
    top: 1rem;
    align-self: start;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--bento-gap);
  }

  .col-span-2 {
    grid-column: span 2;
  }

  /* ── Bento tile ── */
  .bento-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 0.75rem;
    min-height: 80px;
    background: var(--bento-active-bg);
    border: 1px solid var(--bento-border);
    border-radius: var(--bento-radius);
    text-decoration: none;
    color: var(--bento-text);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    cursor: pointer;
  }

  .bento-tile.col-span-2 {
    flex-direction: row;
    gap: 0.75rem;
    min-height: 72px;
    padding: 1rem 1.25rem;
  }

  .bento-tile:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px -4px rgba(0, 0, 0, 0.1);
    border-color: var(--bento-orange);
  }

  .bento-tile:active {
    transform: translateY(0);
    box-shadow: none;
  }

  .bento-tile.active {
    border-color: var(--bento-red);
    background: #fff8f0;
    box-shadow: 0 0 0 1px var(--bento-red);
  }

  .bento-tile.active .bento-tile-icon {
    color: var(--bento-red);
  }

  .bento-tile.active .bento-tile-label {
    color: var(--bento-red);
    font-weight: 700;
  }

  .bento-tile-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: var(--bento-text);
    flex-shrink: 0;
  }

  .bento-tile-icon svg {
    width: 24px;
    height: 24px;
  }

  .bento-tile.col-span-2 .bento-tile-icon svg {
    width: 26px;
    height: 26px;
  }

  .bento-tile-label {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--bento-text);
    line-height: 1.2;
    text-align: center;
  }

  .bento-tile.col-span-2 .bento-tile-label {
    font-size: 0.9375rem;
    text-align: left;
  }

  .bento-tile:focus-visible {
    outline: 2px solid var(--bento-red);
    outline-offset: 3px;
    border-radius: var(--bento-radius);
  }

  /* ── Mobile overlay ── */
  .bento-overlay {
    display: none;
    position: fixed;
    inset: 0;
    top: 56px;
    background: #fdfdf8;
    border-top: 1px solid var(--bento-border);
    z-index: 999997;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .bento-overlay.open { transform: translateX(0); }

  .bento-overlay-nav {
    padding: 1.5rem;
  }

  .bento-overlay-nav .bento-grid {
    gap: 0.625rem;
  }

  .bento-overlay-nav .bento-tile {
    min-height: 72px;
    background: #e5e7e0;
    border: none;
    border-radius: 14px;
  }

  .bento-overlay-nav .bento-tile.active {
    background: #fff8f0;
    border: 1px solid var(--bento-red);
  }

  .bento-overlay-nav .bento-tile.col-span-2 {
    min-height: 64px;
    padding: 0.875rem 1.25rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .bento-topbar {
      display: flex;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
    }
    .bento-hamburger { display: flex; }
    .bento-panel { display: none; }
    .bento-overlay { display: block; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bento-logo-svg,
    .bento-tile,
    .bento-hamburger .bar,
    .bento-overlay {
      transition: none;
    }
    .bento-logo:hover .bento-logo-svg { transform: none; }
    .bento-tile:hover { transform: none; }
  }
</style>
