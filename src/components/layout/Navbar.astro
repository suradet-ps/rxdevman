---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/tools', label: 'Tools' },
  { href: '/hosxp', label: 'HOSxP' },
  { href: '/invs', label: 'INVS' },
  { href: '/about', label: 'About' },
];

const pathname = Astro.url.pathname;
---

<header class="navbar" id="navbar">
  <div class="navbar-inner">

    <!-- Logo -->
    <a href="/" class="logo" aria-label="rxdevman Homepage">
      <svg
        class="logo-svg"
        width="32"
        height="32"
        viewBox="0 0 200 200"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M40 30 V170 M40 30 H110 C145 30 160 55 160 80 C160 110 140 125 110 125 H40 M110 125 L160 170"
          fill="none"
          stroke="#F54E00"
          stroke-width="18"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M85 65 L115 95 M115 65 L85 95"
          fill="none"
          stroke="#F54E00"
          stroke-width="15"
          stroke-linecap="round"
        />
      </svg>
      <span class="logo-text">
        <span class="logo-rx">rx</span><span class="logo-devman">devman</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => {
        const isActive
          = href === '/'
            ? pathname === '/'
            : pathname.startsWith(href);
        return (
          <a
            href={href}
            class:list={['nav-link', { active: isActive }]}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Right: CTA + hamburger -->
    <div class="navbar-right">
      <a href="/blog" class="cta-btn">Get Started</a>
      <button
        class="hamburger"
        id="hamburger"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="mobile-overlay"
      >
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>

  </div>
</header>

<!-- Mobile overlay (outside header so it can be full-screen) -->
<div class="mobile-overlay" id="mobile-overlay" aria-hidden="true">
  <nav class="mobile-nav" aria-label="Mobile navigation">
    {navLinks.map(({ href, label }) => {
      const isActive
        = href === '/'
          ? pathname === '/'
          : pathname.startsWith(href);
      return (
        <a
          href={href}
          class:list={['mobile-link', { active: isActive }]}
        >
          {label}
        </a>
      );
    })}
    <a href="/blog" class="cta-btn mobile-cta">Get Started</a>
  </nav>
</div>

<script>
  const hamburger = document.getElementById('hamburger');
  const overlay = document.getElementById('mobile-overlay');

  function openMenu() {
    overlay?.classList.add('open');
    hamburger?.classList.add('active');
    hamburger?.setAttribute('aria-expanded', 'true');
    overlay?.setAttribute('aria-hidden', 'false');
    document.body.classList.add('no-scroll');
  }

  function closeMenu() {
    overlay?.classList.remove('open');
    hamburger?.classList.remove('active');
    hamburger?.setAttribute('aria-expanded', 'false');
    overlay?.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('no-scroll');
  }

  hamburger?.addEventListener('click', () => {
    overlay?.classList.contains('open') ? closeMenu() : openMenu();
  });

  overlay?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
</script>

<style>
  /* ─── Design tokens (local, mirror global) ─── */
  :root {
    --nav-accent:  #e5e7e0;
    --nav-border:  #bfc1b7;
    --nav-text:    #4d4f46;
    --nav-red:     #f54e00;
    --nav-orange:  #eb9d2a;
    --nav-shadow:  #cd8407;
    --nav-bg:      #fdfdf8;
    --nav-height:  56px;
  }

  /* ─── Header bar ─── */
  /*
   * PostHog: nav inner is always bg-accent (#E5E7E0) with border-b (#BFC1B7).
   * No transparent-then-scroll trick — the bar is always visible and solid.
   */
  .navbar {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 999998;
    background: var(--nav-accent);
    border-bottom: 1px solid var(--nav-border);
  }

  .navbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  /* ─── Logo ─── */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-svg {
    width: 32px;
    height: 32px;
    transition: transform 0.3s ease;
  }

  .logo:hover .logo-svg {
    transform: rotate(-12deg) scale(1.08);
  }

  .logo-text {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .logo-rx      { color: var(--nav-red); }
  .logo-devman  { color: var(--nav-text); }

  /* ─── Desktop nav links ─── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.125rem;   /* 2px — PostHog packs links tightly */
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 0.84375rem;   /* 13.5px — PostHog exact */
    font-weight: 500;
    color: var(--nav-text);
    text-decoration: none;
    padding: 0.25rem 0.625rem;  /* 4px 10px */
    border-radius: 6px;
    opacity: 0.75;             /* PostHog: inactive links at 70% */
    transition: opacity 0.15s ease, background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    opacity: 1;
    color: var(--nav-red);
    background: rgba(0, 0, 0, 0.06);
  }

  .nav-link.active {
    opacity: 1;
    color: var(--nav-red);
  }

  /* ─── Right cluster ─── */
  .navbar-right {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
  }

  /* ─── CTA button (3D tactile) ─── */
  .cta-btn {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: #1a1a1a;
    background: var(--nav-orange);
    text-decoration: none;
    padding: 0.4rem 1.1rem;
    border-radius: 6px;
    border: 1px solid var(--nav-shadow);
    border-bottom: 3px solid var(--nav-shadow);
    cursor: pointer;
    white-space: nowrap;
    display: inline-block;
    line-height: 1.4;
    transition: transform 0.12s ease, border-bottom-width 0.12s ease;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
  }

  .cta-btn:active {
    transform: translateY(1px);
    border-bottom-width: 1px;
  }

  /* ─── Hamburger ─── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--nav-border);
    border-radius: 6px;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: background 0.15s ease;
  }

  .hamburger:hover { background: rgba(0,0,0,0.06); }

  .bar {
    width: 15px;
    height: 2px;
    background: var(--nav-text);
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.28s ease, opacity 0.28s ease;
  }

  .hamburger.active .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.active .bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.active .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ─── Mobile overlay ─── */
  .mobile-overlay {
    display: none;       /* show only on small screens via media query */
    position: fixed;
    inset: 0;
    top: var(--nav-height);
    background: var(--nav-bg);
    border-top: 1px solid var(--nav-border);
    z-index: 999997;
    overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-overlay.open { transform: translateX(0); }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    gap: 0.25rem;
  }

  .mobile-link {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--nav-text);
    text-decoration: none;
    padding: 0.7rem 1rem;
    border-radius: 8px;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .mobile-link:hover,
  .mobile-link.active {
    color: var(--nav-red);
    background: var(--nav-accent);
  }

  .mobile-cta {
    margin-top: 1.25rem;
    text-align: center;
    padding: 0.65rem 1rem;
    font-size: 1rem;
    border-radius: 8px;
    box-shadow: 0 3px 0 var(--nav-shadow);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .nav-links        { display: none; }
    .cta-btn:not(.mobile-cta) { display: none; }
    .hamburger        { display: flex; }
    .mobile-overlay   { display: block; }
  }

  /* ─── Focus styles ─── */
  .nav-link:focus-visible,
  .logo:focus-visible,
  .hamburger:focus-visible,
  .cta-btn:focus-visible {
    outline: 2px solid var(--nav-red);
    outline-offset: 3px;
    border-radius: 6px;
  }

  /* ─── Global side-effects ─── */
  :global(body.no-scroll) { overflow: hidden; }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .logo-svg, .nav-link, .cta-btn, .hamburger, .bar, .mobile-overlay {
      transition: none;
    }
    .logo:hover .logo-svg { transform: none; }
  }
</style>
