---
const navLinks = [
  { href: '/', label: 'Home', icon: 'home' },
  { href: '/blog', label: 'Blog', icon: 'blog' },
  { href: '/tools', label: 'Tools', icon: 'tools' },
  { href: '/hosxp', label: 'HOSxP', icon: 'hosxp' },
  { href: '/invs', label: 'INVS', icon: 'invs' },
  { href: '/about', label: 'About', icon: 'about' },
];

const pathname = Astro.url.pathname;

function isActive(href: string) {
  return href === '/' ? pathname === '/' : pathname.startsWith(href);
}
---

<header class="navbar" id="navbar">
  <div class="navbar-inner">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="rxdevman Homepage">
      <svg class="logo-svg" width="28" height="28" viewBox="0 0 200 200" aria-hidden="true">
        <path d="M40 30 V170 M40 30 H110 C145 30 160 55 160 80 C160 110 140 125 110 125 H40 M110 125 L160 170" fill="none" stroke="currentColor" stroke-width="18" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M85 65 L115 95 M115 65 L85 95" fill="none" stroke="currentColor" stroke-width="15" stroke-linecap="round" />
      </svg>
      <span class="logo-text"><span class="logo-rx">rx</span><span class="logo-devman">devman</span></span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={['nav-link', { active: isActive(href) }]}
        >
          <span class="nav-link-text">{label}</span>
        </a>
      ))}
    </nav>

    <!-- Right area (mobile hamburger only) -->
    <div class="navbar-right">
      <button class="hamburger" id="hamburger" aria-label="Toggle navigation" aria-expanded="false" aria-controls="mobile-overlay">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile overlay -->
<div class="mobile-overlay" id="mobile-overlay" aria-hidden="true">
  <div class="mobile-overlay-header">
    <a href="/" class="logo mobile-overlay-logo" aria-label="rxdevman Homepage">
      <svg class="logo-svg" width="28" height="28" viewBox="0 0 200 200" aria-hidden="true">
        <path d="M40 30 V170 M40 30 H110 C145 30 160 55 160 80 C160 110 140 125 110 125 H40 M110 125 L160 170" fill="none" stroke="currentColor" stroke-width="18" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M85 65 L115 95 M115 65 L85 95" fill="none" stroke="currentColor" stroke-width="15" stroke-linecap="round" />
      </svg>
      <span class="logo-text"><span class="logo-rx">rx</span><span class="logo-devman">devman</span></span>
    </a>

    <button class="mobile-close" id="mobile-close" aria-label="Close navigation">
      <span class="mobile-close-bar"></span>
      <span class="mobile-close-bar"></span>
    </button>
  </div>

  <nav class="mobile-nav" aria-label="Mobile navigation">
    {navLinks.map(({ href, label, icon }) => (
      <a
        href={href}
        class:list={['mobile-link', { active: isActive(href) }]}
      >
        <span class="mobile-link-icon">
          {icon === 'home' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
          )}
          {icon === 'blog' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
          )}
          {icon === 'tools' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" /></svg>
          )}
          {icon === 'hosxp' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2" /></svg>
          )}
          {icon === 'invs' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" /><rect x="8" y="2" width="8" height="4" rx="1" ry="1" /></svg>
          )}
          {icon === 'about' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
          )}
        </span>
        <span class="mobile-link-text">{label}</span>
      </a>
    ))}
  </nav>
</div>

<script>
const navbar = document.getElementById('navbar');
const hamburger = document.getElementById('hamburger');
const overlay = document.getElementById('mobile-overlay');
const mobileClose = document.getElementById('mobile-close');

if (navbar instanceof HTMLElement && hamburger instanceof HTMLButtonElement && overlay instanceof HTMLDivElement && mobileClose instanceof HTMLButtonElement && !overlay.dataset.initialized) {
  const navbarElement = navbar;
  const hamburgerButton = hamburger;
  const overlayElement = overlay;
  const closeButton = mobileClose;

  overlayElement.dataset.initialized = 'true';

  const overlayFocusable = Array.from(overlayElement.querySelectorAll<HTMLElement>('a, button'));
  let scrollFrame = 0;
  let isMenuOpen = false;
  let isScrolled = false;

  function syncScrollState() {
    scrollFrame = 0;
    const nextScrolled = window.scrollY > 20;
    if (nextScrolled === isScrolled)
      return;

    isScrolled = nextScrolled;
    navbarElement.classList.toggle('scrolled', nextScrolled);
  }

  function requestScrollState() {
    if (scrollFrame)
      return;

    scrollFrame = window.requestAnimationFrame(syncScrollState);
  }

  function setMenuState(nextOpen: boolean) {
    if (nextOpen === isMenuOpen)
      return;

    isMenuOpen = nextOpen;

    // State Management: Always reset instant-close when opening the menu.
    // This prevents the overlay from getting stuck in a no-transition state
    // (e.g., if navigation fails or the user uses the browser back button in SPA).
    if (nextOpen) {
      overlayElement.classList.remove('instant-close');
    }

    overlayElement.classList.toggle('open', nextOpen);
    hamburgerButton.classList.toggle('active', nextOpen);
    hamburgerButton.setAttribute('aria-expanded', String(nextOpen));
    overlayElement.setAttribute('aria-hidden', String(!nextOpen));
    document.body.classList.toggle('no-scroll', nextOpen);
    overlayElement.inert = !nextOpen;

    if (nextOpen) {
      closeButton.focus();
    }
    else {
      hamburgerButton.focus();
    }
  }

  function handleOverlayKeydown(event: KeyboardEvent) {
    if (!isMenuOpen || event.key !== 'Tab')
      return;

    const focusable = overlayFocusable;
    const firstFocusable = focusable[0];
    const lastFocusable = focusable[focusable.length - 1];

    if (event.shiftKey && document.activeElement === firstFocusable) {
      event.preventDefault();
      lastFocusable?.focus();
    }
    else if (!event.shiftKey && document.activeElement === lastFocusable) {
      event.preventDefault();
      firstFocusable?.focus();
    }
  }

  overlayElement.inert = true;
  requestScrollState();

  window.addEventListener('scroll', requestScrollState, { passive: true });
  window.addEventListener('resize', () => {
    if (window.innerWidth > 900) {
      setMenuState(false);
    }

    requestScrollState();
  }, { passive: true });

  hamburgerButton.addEventListener('click', () => {
    setMenuState(!isMenuOpen);
  });

  closeButton.addEventListener('click', () => {
    setMenuState(false);
  });

  overlayElement.addEventListener('click', (event) => {
    const link = event.target instanceof Element ? event.target.closest('a') : null;
    if (link) {
      overlayElement.classList.add('instant-close');
      setMenuState(false);
      void overlayElement.offsetHeight;
    }
  });

  overlayElement.addEventListener('keydown', handleOverlayKeydown);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && isMenuOpen)
      setMenuState(false);
  });
}
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    width: 100%;
    z-index: var(--z-navbar);
    background: var(--surface-page);
    border-bottom: 1px solid var(--border-accent);
  }

  .navbar::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 8px;
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
    opacity: 0;
    transition: opacity var(--duration-300) var(--ease);
    pointer-events: none;
  }

  .navbar.scrolled::after { opacity: 1; }

  .navbar-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
    color: var(--brand-red);
  }

  .logo-svg {
    width: 26px;
    height: 26px;
    transition: transform var(--duration-300) var(--ease-spring);
  }

  .logo:hover .logo-svg { transform: rotate(-16deg) scale(1.1); }

  .logo-text {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .logo-rx { color: var(--brand-red); }
  .logo-devman { color: var(--text-primary); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    justify-content: flex-end;
  }

  .nav-link {
    position: relative;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    padding: 0.45rem 1.1rem;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    border: 1.5px solid transparent;
    border-bottom-width: 3px;
    transition: color var(--duration-200) var(--ease),
      background var(--duration-200) var(--ease),
      border-color var(--duration-200) var(--ease);
  }

  .nav-link:hover {
    color: var(--brand-red);
    background: color-mix(in srgb, var(--brand-red) 6%, transparent);
  }

  .nav-link.active {
    color: #2b1f00;
    background: var(--brand-orange);
    border-color: var(--brand-btn-border);
    font-weight: 700;
  }

  .nav-link-text { position: relative; z-index: 1; }

  .navbar-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-sm);
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: background var(--duration-200) var(--ease),
      border-color var(--duration-200) var(--ease);
  }

  .hamburger:hover {
    background: color-mix(in srgb, var(--brand-red) 6%, transparent);
    border-color: var(--brand-red);
  }

  .bar {
    width: 16px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transform-origin: center;
    transition: transform var(--duration-300) var(--ease-spring),
      opacity var(--duration-200) var(--ease);
    will-change: transform;
  }

  .hamburger.active .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); background: var(--brand-red); }
  .hamburger.active .bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.active .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); background: var(--brand-red); }

  .mobile-overlay {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100dvh;
    background: var(--surface-page);
    z-index: var(--z-overlay);
    overflow-y: auto;
    overscroll-behavior: contain;
    transform: translateX(100%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: transform var(--duration-300) var(--ease-panel),
      opacity var(--duration-300) var(--ease);
    will-change: transform;
  }

  .mobile-overlay.open {
    transform: translateX(0);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-overlay.instant-close {
    transition: none;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .mobile-overlay-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: calc(var(--nav-height) + env(safe-area-inset-top));
    padding: env(safe-area-inset-top) 1.5rem 0;
    background: var(--surface-page);
    border-bottom: 1px solid var(--border-accent);
  }

  .mobile-overlay-logo { min-height: var(--nav-height); }

  .mobile-close {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    min-width: 40px;
    background: transparent;
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    cursor: pointer;
    transition: background var(--duration-200) var(--ease),
      border-color var(--duration-200) var(--ease),
      color var(--duration-200) var(--ease);
  }

  .mobile-close:hover {
    background: color-mix(in srgb, var(--brand-red) 6%, transparent);
    border-color: var(--brand-red);
    color: var(--brand-red);
  }

  .mobile-close-bar {
    position: absolute;
    width: 18px;
    height: 2px;
    background: currentColor;
    border-radius: var(--radius-full);
  }

  .mobile-close-bar:nth-child(1) { transform: rotate(45deg); }
  .mobile-close-bar:nth-child(2) { transform: rotate(-45deg); }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    min-height: calc(100dvh - var(--nav-height) - env(safe-area-inset-top));
    padding: 1rem 1.5rem max(2rem, env(safe-area-inset-bottom));
    gap: 0.25rem;
  }

  .mobile-link {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    padding: 0.85rem 1rem;
    border-radius: var(--radius-lg);
    border: 1.5px solid transparent;
    border-bottom-width: 3px;
    transition: color var(--duration-200) var(--ease),
      background var(--duration-200) var(--ease),
      border-color var(--duration-200) var(--ease),
      transform var(--duration-200) var(--ease);
  }

  .mobile-link:hover {
    color: var(--brand-red);
    background: color-mix(in srgb, var(--brand-red) 6%, transparent);
  }

  @media (hover: hover) and (pointer: fine) {
    .mobile-link:hover { transform: translateX(4px); }
  }

  .mobile-link.active {
    color: #2b1f00;
    background: var(--brand-orange);
    border-color: var(--brand-btn-border);
    font-weight: 700;
    transform: none;
  }

  .mobile-link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    background: var(--surface-page);
    border: 1px solid var(--border-accent);
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color var(--duration-200) var(--ease),
      background var(--duration-200) var(--ease),
      border-color var(--duration-200) var(--ease);
  }

  .mobile-link.active .mobile-link-icon,
  .mobile-link:hover .mobile-link-icon {
    color: var(--brand-red);
    border-color: var(--brand-red);
    background: var(--color-white);
  }

  .mobile-link.active .mobile-link-icon {
    color: #2b1f00;
    border-color: rgba(43, 31, 0, 0.2);
    background: rgba(255, 255, 255, 0.4);
  }

  .mobile-link-text { line-height: 1.3; }

  @media (max-width: 900px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .mobile-overlay { display: block; }
  }

  .nav-link:focus-visible,
  .logo:focus-visible,
  .hamburger:focus-visible,
  .mobile-link:focus-visible,
  .mobile-close:focus-visible {
    outline: var(--focus-ring-red);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  :global(body.no-scroll) {
    overflow: hidden;
  }

  :global(html) { scrollbar-gutter: stable; }

  @media (prefers-reduced-motion: reduce) {
    .navbar,
    .navbar::after,
    .logo-svg,
    .nav-link,
    .hamburger,
    .bar,
    .mobile-overlay,
    .mobile-link {
      transition: none;
      animation: none;
    }
    .logo:hover .logo-svg { transform: none; }
    .mobile-link:hover { transform: none; }
  }
</style>
