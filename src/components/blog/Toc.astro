---
import type { MarkdownHeading } from 'astro';

type Props = {
  headings: MarkdownHeading[];
};

const { headings } = Astro.props;

const filteredHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---
{filteredHeadings.length > 1 && (
  <nav class="toc">
    <h3 class="toc-title">On this page</h3>
    <ul class="toc-list">
      {filteredHeadings.map(heading => (
        <li class={`toc-item depth-${heading.depth}`}>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
type TocWindow = Window & {
  __rxdevmanTocObserver?: IntersectionObserver;
};

function initToc() {
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-item a'));
  if (tocLinks.length === 0)
    return;

  const tocWindow = window as TocWindow;
  tocWindow.__rxdevmanTocObserver?.disconnect();

  const observer = new IntersectionObserver((entries) => {
    const intersectingEntries = entries.filter(entry => entry.isIntersecting);

    if (intersectingEntries.length === 0)
      return;

    intersectingEntries.sort(
      (a, b) => a.boundingClientRect.top - b.boundingClientRect.top,
    );

    const activeEntry = intersectingEntries[0];
    const id = activeEntry.target.getAttribute('id');

    tocLinks.forEach((link) => {
      link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
    });
  }, {
    rootMargin: '0px 0px -80% 0px',
    threshold: 1,
  });

  document.querySelectorAll('.prose h2, .prose h3').forEach((heading) => {
    observer.observe(heading);
  });

  tocWindow.__rxdevmanTocObserver = observer;
}

document.addEventListener('astro:page-load', initToc);
initToc();
</script>

<style>
  .toc {
    padding: var(--space-4) 0;
  }
  .toc-title {
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
    color: var(--font-color-light);
  }
  .toc-list {
    list-style: none;
    padding: 0;
  }
  .toc-item a {
    display: block;
    padding: var(--space-2) 0;
    font-size: 0.9rem;
    color: var(--font-color-light);
    border-left: 2px solid var(--card-border-color);
    padding-left: var(--space-4);
    transition: color var(--duration-200) var(--ease), border-color var(--duration-200) var(--ease), transform var(--duration-200) var(--ease);
  }
  .toc-item a:hover {
    color: var(--font-color);
    border-left-color: var(--font-color);
  }
  .toc-item a.active {
    color: var(--brand-color);
    border-left-color: var(--brand-color);
    font-weight: 500;
    transform: translateX(4px);
  }
  .toc-item.depth-3 a {
    padding-left: var(--space-8);
  }
</style>
