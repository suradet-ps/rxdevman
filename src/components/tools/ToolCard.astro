---
import { Icon } from 'astro-icon/components';

type Props = {
  title: string;
  description: string;
  href: string;
  icon?: string;
};
const { title, description, href, icon } = Astro.props;
---
<a href={href} class="card tool-card">
  <div class="icon-wrapper">
    {icon ? <Icon name={icon} class="card-icon" /> : <slot name="icon" />}
  </div>
  <div class="text-content">
    <h2>{title}</h2>
    <p>{description}</p>
  </div>
  <span class="cta-arrow">&rarr;</span>
</a>
<style>
  .tool-card {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    text-decoration: none;
    color: var(--font-color);
  }
  .icon-wrapper {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-md);
  }
  .card-icon {
    font-size: 1.75rem;
    color: var(--brand-color);
    width: 32px;
    height: 32px;
  }
  .card-icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  h2 {
    margin: 0 0 var(--space-1);
  }
  p {
    margin: 0;
    font-size: var(--text-base);
  }
  .cta-arrow {
    margin-left: auto;
    font-size: var(--text-2xl);
    color: var(--font-color-light);
    transition: transform var(--duration-200) var(--ease), color var(--duration-200) var(--ease);
  }
  .tool-card:hover .cta-arrow {
    color: var(--brand-color);
    transform: translateX(5px);
  }
  .tool-card:focus-visible {
    outline: 3px solid var(--brand-color);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-arrow {
      transition: none;
    }
    .tool-card:hover .cta-arrow {
      transform: none;
    }
  }
</style>
