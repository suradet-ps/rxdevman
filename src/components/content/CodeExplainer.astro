---
import { Icon } from 'astro-icon/components';

type Props = {
  title: string;
};
const { title } = Astro.props;
---
<div class="explainer-box">
  <div class="header">
    <Icon name="heroicons:code-bracket" class="header-icon" />
    <span class="title">{title}</span>
  </div>
  <div class="content">
    <slot />
  </div>
</div>

<style>
  .explainer-box {
    background-color: var(--card-bg-color);
    border: 1px solid var(--card-border-color);
    border-radius: var(--radius-md);
    margin: var(--space-10) 0;
    overflow: hidden;
    box-shadow: 0 4px 12px var(--shadow-color);
  }

  .header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    background-color: color-mix(in srgb, var(--card-bg-color) 80%, var(--card-border-color));
    border-bottom: 1px solid var(--card-border-color);
  }

  .header-icon {
    font-size: var(--text-xl);
    color: var(--font-color-light);
  }

  .title {
    font-weight: 500;
    color: var(--font-color);
    font-family: var(--font-mono);
  }

  .content {
    padding: var(--space-4) var(--space-5);
  }
  .content :global(details) {
    border-bottom: 1px solid var(--card-border-color);
    padding: var(--space-4) 0;
  }
  .content :global(details:first-child) { padding-top: 0; }
  .content :global(details:last-child) { border-bottom: none; padding-bottom: 0; }

  .content :global(summary) {
    cursor: pointer;
    font-weight: 600;
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--font-color);
    transition: color var(--duration-200) var(--ease);
  }
  .content :global(summary:hover) {
    color: var(--brand-color);
  }

  .content :global(summary::-webkit-details-marker) { display: none; }

  .content :global(summary::before) {
    content: '▶';
    font-size: 0.6em;
    color: var(--brand-color);
    transition: transform var(--duration-200) var(--ease);
    margin-right: var(--space-1);
  }
  .content :global(details[open] > summary::before) {
    transform: rotate(90deg);
  }

  .content :global(details p) {
    margin-top: var(--space-3);
    margin-bottom: 0;
    padding-left: var(--space-6);
    color: var(--font-color-light);
    line-height: 1.7;
    border-left: 2px solid var(--card-border-color);
  }
</style>
