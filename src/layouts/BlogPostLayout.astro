---
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';

import { getImage, Image } from 'astro:assets';

import RelatedPosts from '@/components/blog/RelatedPosts.astro';
import ShareButtons from '@/components/blog/ShareButtons.astro';
import Toc from '@/components/blog/Toc.astro';
import ViewCounter from '@/components/blog/ViewCounter.astro';
import { getAllBlogPosts } from '@/lib/blog';
import { getRelatedPosts } from '@/utils/post-utils';
import { slugify } from '@/utils/slugify';

import BaseLayout from './BaseLayout.astro';

type Props = {
  frontmatter: CollectionEntry<'blog'>['data'];
  headings: MarkdownHeading[];
  slug?: string;
};

const { frontmatter, headings, slug } = Astro.props;
const { title, description, pubDate, heroImage, category, tags } = frontmatter;

const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Use the provided slug or generate from title as a database key
const postSlug = slug || slugify(title);

// Fetch all blog posts (cached) and compute related posts
const allPosts = await getAllBlogPosts();
const relatedPosts = getRelatedPosts(allPosts, postSlug, tags, category, 3);

// Pre-generate the hero image URL for <link rel="preload"> to improve LCP
const preloadHero = heroImage
  ? await getImage({ src: heroImage, width: 1200, quality: 85, format: 'webp' })
  : null;
---

<BaseLayout title={title} description={description}>
  {preloadHero && (
    <link
      slot="head"
      rel="preload"
      as="image"
      href={preloadHero.src}
      type="image/webp"
      fetchpriority="high"
    />
  )}
  <div class="layout-grid">
    <aside class="left-sidebar"></aside>
    <article class="prose">
      <header class="post-header">
        <a
          href={`/blog/categories/${slugify(category)}`}
          class="category-link"
        >{category}</a
        >
        <h1>{title}</h1>
        <p class="description">{description}</p>
        <div class="meta">
          <span>Published on {formattedDate}</span>
          <span class="separator">•</span>
          <!-- เรียกใช้ ViewCounter ตรงนี้ -->
          <ViewCounter slug={postSlug} />
        </div>
      </header>

      {
        heroImage && (
          <Image
            src={heroImage}
            alt={`Hero image for ${title}`}
            class="hero-image"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            quality={85}
            format="webp"
            widths={[768, 1024, 1200, 1536]}
            sizes="(max-width: 768px) 100vw, (max-width: 1024px) 100vw, 800px"
          />
        )
      }

      <div class="post-content">
        <slot />
      </div>

      <footer class="post-footer">
        <ShareButtons title={title} url={Astro.url} />

        <div class="tags-list">
          {
            tags.map(tag => (
              <a href={`/blog/tags/${slugify(tag)}`} class="tag-chip">
                {tag}
              </a>
            ))
          }
        </div>
      </footer>

      <RelatedPosts relatedPosts={relatedPosts} />
    </article>

    <aside class="right-sidebar">
      <Toc headings={headings} />
    </aside>
  </div>
</BaseLayout>

<style>
  .layout-grid {
    display: grid;
    grid-template-columns: minmax(1.5rem, 1fr) minmax(0, 800px) minmax(
        1.5rem,
        240px
      );
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  .prose {
    grid-column: 2;
  }

  .right-sidebar {
    grid-column: 3;
    position: sticky;
    top: 80px;
    align-self: start;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
  }

  /* ── Post Header ── */
  .post-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .category-link {
    font-family: 'Source Code Pro', monospace;
    text-transform: uppercase;
    font-size: 0.75rem;
    font-weight: 600;
    color: #F54E00;
    letter-spacing: 0.08em;
    text-decoration: none;
  }

  .category-link:hover {
    color: #EB9D2A;
  }

  h1 {
    margin: 0.5rem 0 1rem;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-family: 'IBM Plex Sans', 'Noto Sans Thai', system-ui, sans-serif;
    font-weight: 700;
    color: #23251D;
    line-height: 1.2;
  }

  .description {
    font-size: 1rem;
    color: #65675E;
    max-width: 680px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
  }

  /* ── Meta ── */
  .meta {
    font-size: 0.875rem;
    color: #9EA096;
    font-family: 'IBM Plex Sans', 'Noto Sans Thai', system-ui, sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .separator {
    color: #BFC1B7;
  }

  /* ── Hero Image — PostHog 3D card style ── */
  .hero-image {
    width: 100%;
    max-height: 600px;
    object-fit: cover;
    object-position: center;
    border: 1px solid #BFC1B7;
    border-bottom: 3px solid #BFC1B7;
    border-radius: 8px;
    margin-bottom: 3rem;
    display: block;
  }

  /* ── Post Footer ── */
  .post-footer {
    margin-top: 4rem;
    border-top: 1px solid #BFC1B7;
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ── Tags ── */
  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .tag-chip {
    background: #ffffff;
    border: 1px solid #BFC1B7;
    border-bottom: 3px solid #BFC1B7;
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    color: #4D4F46;
    font-size: 0.8125rem;
    font-family: 'IBM Plex Sans', 'Noto Sans Thai', system-ui, sans-serif;
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      transform 0.15s ease;
  }

  .tag-chip:hover {
    border-color: #EB9D2A;
    border-bottom-color: #EB9D2A;
    transform: translateY(-2px);
    color: #23251D;
  }

  .tag-chip:focus-visible {
    outline: 2px solid #F54E00;
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-chip {
      transition: none;
    }
  }

  @media (max-width: 1024px) {
    .layout-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 1.5rem;
      padding: 0 var(--space-6);
    }
    .left-sidebar,
    .right-sidebar {
      display: none;
    }
    .prose {
      grid-column: 1;
    }
  }

  @media (max-width: 768px) {
    .layout-grid {
      padding: 0 var(--space-4);
    }
    .post-header {
      margin-bottom: 2rem;
    }
    .hero-image {
      border-radius: 0;
      border-left: none;
      border-right: none;
      margin-left: -1rem;
      margin-right: -1rem;
      width: calc(100% + 2rem);
      max-width: calc(100% + 2rem);
    }
  }
</style>
