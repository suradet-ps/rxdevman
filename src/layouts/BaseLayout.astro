---
import Navbar from '@/components/layout/Navbar.astro';
import ProgressBar from '@/components/ui/ProgressBar.astro';
import '@/styles/global.css';
import '@/styles/terminal.css';

type Props = {
  title: string;
  description?: string;
};
const {
  title,
  description = 'A developer\'s living knowledge base, curated by a pharmacist turned programmer.',
} = Astro.props;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#E5E7E0" />
    <title>{`${title} | rxdevman`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Source+Code+Pro:wght@400;500&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Source+Code+Pro:wght@400;500&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap"
      />
    </noscript>
    <slot name="head" />
  </head>
  <body>
    <ProgressBar />

    <Navbar />

    <div class="page-layout">
      <main>
        <slot />
      </main>
    </div>

    <footer class="site-footer">
      <div class="footer-inner">

        <div class="footer-split">
          <!-- Left: Brand -->
          <div class="footer-brand">
            <a href="/" class="footer-logo" aria-label="rxdevman home">
              <svg width="24" height="24" viewBox="0 0 200 200" aria-hidden="true">
                <path d="M40 30 V170 M40 30 H110 C145 30 160 55 160 80 C160 110 140 125 110 125 H40 M110 125 L160 170" fill="none" stroke="#F54E00" stroke-width="18" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M85 65 L115 95 M115 65 L85 95" fill="none" stroke="#F54E00" stroke-width="15" stroke-linecap="round" />
              </svg>
              <span class="footer-logo-text">rxdevman</span>
            </a>
            <p class="footer-tagline">A developer's living knowledge base, curated by a pharmacist turned programmer.</p>
          </div>

          <!-- Right: Links -->
          <div class="footer-links">
            <a href="/">Home</a>
            <a href="/blog">Blog</a>
            <a href="/tools">Tools</a>
            <a href="/hosxp">HOSxP</a>
            <a href="/invs">INVS</a>
            <a href="/about">About</a>
            <a href="https://github.com/suradet-ps/" target="_blank" rel="noopener noreferrer" class="footer-link-social">GitHub</a>
            <a href="mailto:pharmacistsabot@gmail.com" class="footer-link-social">Email</a>
          </div>
        </div>

        <div class="footer-bottom">
          <span>&copy; {currentYear} rxdevman. All rights reserved.</span>
        </div>

      </div>
    </footer>

    <style>
      /* ── Page layout ── */
      .page-layout {
        max-width: 1440px;
        margin: 0 auto;
        padding: 1rem 1.5rem 1rem;
        min-height: calc(100vh - 340px);
      }

      main {
        min-width: 0;
      }

      @media (max-width: 900px) {
        .page-layout {
          padding: 0;
          min-height: auto;
        }
        main {
          padding: 1.5rem;
        }
      }

      /* ═══════════════════════════════════════════
         Footer — Split Hero
      ═══════════════════════════════════════════ */
      .site-footer {
        background: var(--color-accent-surface);
        border-top: 1px solid var(--color-border);
      }

      .footer-inner {
        max-width: 1440px;
        margin: 0 auto;
        padding: 4rem 1.5rem 2rem;
      }

      .footer-split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: start;
      }

      /* ── Left: Brand ── */
      .footer-brand {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding-left: 1.5rem;
      }

      .footer-logo {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
      }

      .footer-logo svg {
        transition: transform 0.3s ease;
      }

      .footer-logo:hover svg {
        transform: rotate(-12deg) scale(1.08);
      }

      .footer-logo-text {
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--color-near-black);
      }

      .footer-tagline {
        font-size: 0.9375rem;
        color: var(--color-text-muted);
        line-height: 1.7;
        margin: 0;
        max-width: 380px;
      }

      /* ── Right: Links inline with dots ── */
      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 0.75rem;
        align-content: start;
        padding-top: 0.25rem;
      }

      .footer-links a {
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--color-text-primary);
        text-decoration: none;
        transition: color 0.15s ease;
        line-height: 1.8;
      }

      .footer-links a:not(:last-child)::after {
        content: '·';
        color: var(--color-text-muted);
        margin-left: 0.75rem;
        display: inline-block;
        pointer-events: none;
      }

      .footer-links a:hover {
        color: var(--color-brand-red);
      }

      .footer-link-social {
        opacity: 0.7;
      }

      .footer-link-social:hover {
        opacity: 1;
      }

      .footer-links a:focus-visible {
        outline: 2px solid var(--color-brand-red);
        outline-offset: 2px;
        border-radius: 2px;
      }

      /* ── Bottom bar ── */
      .footer-bottom {
        border-top: 1px solid var(--color-border);
        margin-top: 3rem;
        padding: 1.25rem 0 0;
        text-align: center;
        font-size: 0.8125rem;
        color: var(--color-text-muted);
      }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .footer-split {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
        .footer-inner {
          padding: 3rem 1.5rem 1.5rem;
        }
        .footer-brand {
          text-align: center;
          align-items: center;
        }
        .footer-tagline {
          max-width: 100%;
        }
        .footer-links {
          justify-content: center;
        }
        .footer-bottom {
          margin-top: 2rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .footer-logo svg,
        .footer-links a {
          transition: none;
        }
        .footer-logo:hover svg {
          transform: none;
        }
      }
    </style>
  </body>
</html>
