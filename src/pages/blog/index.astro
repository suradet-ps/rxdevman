---
import type { CollectionEntry } from 'astro:content';

import { getCollection } from 'astro:content';

import BlogPostCard from '@/components/blog/BlogPostCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');

// Sort posts by date, newest first
const sortedPosts = allPosts.sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="All Articles">
  <div class="container">

    <div class="blog-header">
      <h1>All Articles</h1>
      <p>
        แหล่งรวบรวมทุกสิ่งที่ผมเขียนไว้ ลองอ่านบันทึกของผมเกี่ยวกับการพัฒนาเว็บ แนวทางปฏิบัติที่ดีที่สุด และสิ่งที่ผมค้นพบด้วยตัวเอง
      </p>
    </div>

    <div class="post-grid">
      {sortedPosts.map((post: CollectionEntry<'blog'>) => (
        <BlogPostCard post={post} />
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .blog-header { text-align: center; margin: 0 auto; padding-bottom: var(--space-2); }
  .blog-header h1 { font-size: clamp(1.35rem, 2.5vw, 1.75rem); margin-bottom: var(--space-2); }
  .blog-header p { font-size: var(--text-base); color: var(--text-secondary); }
</style>
