---
import ViewCounter from '@/components/blog/ViewCounter.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout title="Welcome">

  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="hero-section">
    <div class="container hero-inner">

      <!-- Left: Text -->
      <div class="hero-text">
        <p class="eyebrow">HI, I'M SURADET PRATOMSAK</p>
        <h1 class="hero-headline">
          Pharmacist by Training,<br />
          <span class="headline-accent">Developer by Passion.</span>
        </h1>
        <p class="hero-description">
          Welcome to RxDev Man ^^
          I built this blog to document everything I learn in the world of programming.
          You'll find mostly articles here, along with some tools I've created and maybe more in the future.
          Curious what's here? Dive in and explore.
        </p>
        <div class="hero-cta-row">
          <a href="/blog" class="cta-button">Explore My Notes</a>
          <a href="/about" class="cta-secondary">Read About Me →</a>
        </div>
      </div>

      <!-- Right: Terminal -->
      <div class="hero-image-wrap">
        <div class="terminal">
          <div class="terminal-bar">
            <div class="terminal-dots">
              <span class="terminal-dot dot-red"></span>
              <span class="terminal-dot dot-yellow"></span>
              <span class="terminal-dot dot-green"></span>
            </div>
            <span class="terminal-title">rxdevman — zsh</span>
          </div>

          <div class="terminal-body">
            <div class="line" style="--delay: 0.4s; --chars: 6">
              <span class="prompt">$</span>
              <span class="typed">whoami</span>
            </div>
            <div class="line" style="--delay: 1.6s; --chars: 23">
              <span class="out">&gt;</span>
              <span class="typed">pharmacist -&gt; rustacean</span>
            </div>
            <div class="line" style="--delay: 3s; --chars: 14">
              <span class="prompt">$</span>
              <span class="typed">echo $PASSION</span>
            </div>
            <div class="line" style="--delay: 4.4s; --chars: 27">
              <span class="out">&gt;</span>
              <span class="typed">building things that matter</span>
            </div>
            <div class="line" style="--delay: 5.8s; --chars: 10">
              <span class="prompt">$</span>
              <span class="typed">ls skills/</span>
            </div>
            <div class="line" style="--delay: 7.2s; --chars: 35">
              <span class="typed line-out">Rust Astro Vue TypeScript HOSxP</span>
            </div>
            <div class="line" style="--delay: 9s; --chars: 0">
              <span class="prompt">$</span>
              <span class="cursor">_</span>
            </div>
          </div>

          <div class="terminal-footer">
            <img
              src="/images/common/profile-placeholder.jpg"
              alt=""
              class="terminal-avatar"
            />
            <span class="terminal-username">suradet-ps</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <div class="container" style="text-align: center; padding-block: var(--space-8);">
    <ViewCounter slug="/" label="Total Visitors" labelBefore />
  </div>

</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  /* ── Terminal ── */
  .terminal {
    width: 100%;
    max-width: 500px;
    background: #1a1b1e;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    box-shadow:
      0 8px 0 #0f0f11,
      0 12px 32px rgba(0, 0, 0, 0.15);
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: #2a2b2e;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-full);
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green { background: #28c840; }

  .terminal-title {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    margin-left: auto;
  }

  .terminal-body {
    padding: var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-height: 180px;
  }

  .line {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    opacity: 0;
    animation: appear 0.15s ease forwards;
    animation-delay: var(--delay);
  }

  @keyframes appear {
    to { opacity: 1; }
  }

  .prompt {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--brand-orange);
    flex-shrink: 0;
  }

  .out {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.3);
    flex-shrink: 0;
  }

  .typed {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.8);
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    vertical-align: bottom;
    width: 0;
    animation: typing calc(var(--chars) * 50ms) steps(var(--chars)) forwards;
    animation-delay: var(--delay);
  }

  @keyframes typing {
    to { width: calc(var(--chars) * 1ch); }
  }

  .line-out {
    color: rgba(255, 255, 255, 0.5);
    margin-left: 0;
  }

  .cursor {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--brand-orange);
    animation: blink 0.7s step-end infinite;
    animation-delay: 9.5s;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .terminal-footer {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .terminal-avatar {
    width: 22px;
    height: 22px;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 1.5px solid rgba(255, 255, 255, 0.15);
  }

  .terminal-username {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 1024px) {
    .terminal {
      max-width: 480px;
    }

    .terminal-body {
      min-height: 160px;
      padding: var(--space-3) var(--space-4);
    }
  }

  @media (max-width: 640px) {
    .terminal-body {
      min-height: 140px;
      padding: var(--space-3) var(--space-3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .line {
      opacity: 1;
      animation: none;
    }
    .typed {
      width: auto;
      animation: none;
    }
    .cursor {
      animation: none;
    }
  }
</style>
