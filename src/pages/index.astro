---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Welcome">

  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">

      <!-- Left: Text -->
      <div class="hero-text">
        <p class="eyebrow">HI, I'M SURADET</p>
        <h1 class="hero-headline">
          Pharmacist by Training,<br />
          <span class="headline-accent">Developer by Passion.</span>
        </h1>
        <p class="hero-description">
          ยินดีต้อนรับสู่ RxDev Man นะครับ ^^
          ผมสร้างเว็บบล็อกนี้ขึ้นมาเพื่อบันทึกสิ่งที่ได้เรียนรู้ในโลกของการเขียนโปรแกรม
          ในเว็บบล็อกนี้หลักๆก็จะเน้นไปที่บทความครับ
          อาจจะมีเครื่องมือที่ผมสร้างขึ้นเองบ้าง หรืออาจจะมีอะไรเพิ่มเติมในอนาคต
          ถ้าอยากรู้ว่ามีอะไรบ้าง มาค้นหากันเลยครับ
        </p>
        <div class="hero-cta-row">
          <a href="/blog" class="cta-button">Explore My Notes</a>
          <a href="/about" class="cta-secondary">Read About Me →</a>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="hero-image-wrap">
        <img
          src="/images/common/profile-placeholder.jpg"
          alt="A portrait of the author"
          class="hero-avatar"
        />
      </div>

    </div>
  </section>



</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────── */
  .hero {
    padding: 0 0 6rem;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    align-items: center;
    gap: 5rem;
  }

  /* Eyebrow */
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }

  /* Headline */
  .hero-headline {
    font-size: clamp(2.4rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--color-near-black);
    line-height: 1.12;
    letter-spacing: -0.025em;
    margin-bottom: var(--space-5);
  }

  .headline-accent {
    color: var(--color-brand-red);
  }

  /* Description */
  .hero-description {
    color: var(--color-text-secondary);
    font-size: 1.0625rem;  /* 17px — PostHog body */
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: var(--space-8);
  }

  /* CTA row */
  .hero-cta-row {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .cta-secondary {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-brand-red);
    text-decoration: none;
    transition: color 0.15s ease, gap 0.15s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .cta-secondary:hover {
    color: var(--color-brand-orange);
    gap: 0.5rem;
  }

  /* Profile image */
  .hero-image-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-avatar {
    width: 300px;
    height: 300px;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 4px solid #ffffff;
    box-shadow: 0 0 0 1px var(--color-border), 0 8px 0 var(--color-border);
    flex-shrink: 0;
  }



  /* ── Responsive ───────────────────────── */
  @media (max-width: 1024px) {
    .hero {
      padding: 0 0 4rem;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }

    /* Image on top, text below */
    .hero-image-wrap {
      order: -1;
    }

    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-cta-row {
      justify-content: center;
    }

    .hero-avatar {
      width: 200px;
      height: 200px;
    }

  }

  @media (max-width: 640px) {
    .hero {
      padding: 0 0 3rem;
    }

    .hero-inner {
      gap: 2rem;
    }

    .hero-headline {
      font-size: clamp(1.875rem, 7vw, 2.4rem);
    }

    .hero-avatar {
      width: 160px;
      height: 160px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-secondary {
      transition: none;
    }
    .cta-secondary:hover {
      gap: 0.3rem;
    }
  }
    .feature-card:hover {
      transform: none;
    }
    .cta-secondary:hover {
      transform: none;
    }
  }
</style>
