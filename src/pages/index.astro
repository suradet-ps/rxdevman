---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Welcome">

  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="hero-section">
    <div class="container hero-inner">

      <!-- Left: Text -->
      <div class="hero-text">
        <p class="eyebrow">HI, I'M SURADET</p>
        <h1 class="hero-headline">
          Pharmacist by Training,<br />
          <span class="headline-accent">Developer by Passion.</span>
        </h1>
        <p class="hero-description">
          ยินดีต้อนรับสู่ RxDev Man นะครับ ^^
          ผมสร้างเว็บบล็อกนี้ขึ้นมาเพื่อบันทึกสิ่งที่ได้เรียนรู้ในโลกของการเขียนโปรแกรม
          ในเว็บบล็อกนี้หลักๆก็จะเน้นไปที่บทความครับ
          อาจจะมีเครื่องมือที่ผมสร้างขึ้นเองบ้าง หรืออาจจะมีอะไรเพิ่มเติมในอนาคต
          ถ้าอยากรู้ว่ามีอะไรบ้าง มาค้นหากันเลยครับ
        </p>
        <div class="hero-cta-row">
          <a href="/blog" class="cta-button">Explore My Notes</a>
          <a href="/about" class="cta-secondary">Read About Me →</a>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="hero-image-wrap">
        <img
          src="/images/common/profile-placeholder.jpg"
          alt="A portrait of the author"
          class="hero-avatar"
        />
      </div>

    </div>
  </section>



</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
  }
</style>
