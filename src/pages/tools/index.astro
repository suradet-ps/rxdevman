---
import { Icon } from 'astro-icon/components';

import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Developer Tools">
  <section class="page-tools">
    <div class="container">

      <div class="section-header">
        <h1>Tools & Projects</h1>
        <p>
          Web apps and tools solving real pharmacy and developer problems.
        </p>
      </div>

      <div class="tools-bento">

        <a href="/tools/cupsabot" class="tool-featured">
          <div class="tool-featured-header">
            <div class="tool-featured-icon">
              <Icon name="heroicons:beaker" class="featured-icon-svg" />
            </div>
            <span class="tool-badge">Featured</span>
          </div>
          <div class="tool-featured-body">
            <h2 class="tool-featured-title">ระบบเบิกจ่ายยาออนไลน์</h2>
            <p class="tool-featured-desc">
              เว็บแอปพลิเคชันสำหรับจัดการการเบิกจ่ายยาภายในคปสอ.สระโบสถ์
            </p>
            <div class="tool-tags">
              <span class="tag-chip">Web App</span>
              <span class="tag-chip">Healthcare</span>
              <span class="tag-chip">Stock</span>
            </div>
            <span class="tool-link">ดูรายละเอียด <span class="tool-link-arrow">&rarr;</span></span>
          </div>
        </a>

        <a href="/tools/herbs-app" class="tool-standard">
          <div class="tool-standard-icon">
            <Icon name="heroicons:sparkles" class="standard-icon-svg" />
          </div>
          <div class="tool-standard-body">
            <h2 class="tool-standard-title">บัญชียาสมุนไพร รพ.สระโบสถ์</h2>
            <p class="tool-standard-desc">
              ระบบสืบค้นข้อมูลยาสมุนไพรและเงื่อนไขการเบิกจ่ายของ สปสช.
            </p>
            <div class="tool-tags">
              <span class="tag-chip">Database</span>
              <span class="tag-chip">Herbal</span>
              <span class="tag-chip">Search</span>
            </div>
          </div>
          <span class="tool-standard-arrow">&rarr;</span>
        </a>

      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .page-tools {
    padding: 0.5rem 0 6rem;
  }

  .section-header {
    text-align: center;
    margin-inline: auto;
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-10);
  }

  .section-header h1 {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    margin-bottom: var(--space-2);
  }

  .section-header p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  .tools-bento {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-6);
    align-items: stretch;
  }

  /* ── Featured Card ── */
  .tool-featured {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: var(--surface-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: box-shadow var(--duration-300) var(--ease),
      transform var(--duration-300) var(--ease);
  }

  .tool-featured:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .tool-featured-header {
    position: relative;
    padding: var(--space-10) var(--space-8) var(--space-8);
    background: linear-gradient(135deg, var(--brand-orange), var(--brand-red));
    display: flex;
    align-items: center;
    gap: var(--space-4);
    overflow: hidden;
  }

  .tool-featured-header::after {
    content: '';
    position: absolute;
    bottom: -1.5rem;
    right: -1rem;
    width: 160px;
    height: 160px;
    border-radius: var(--radius-full);
    background: radial-gradient(circle at center, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .tool-featured-icon {
    width: 56px;
    height: 56px;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-md);
  }

  .featured-icon-svg {
    width: 32px;
    height: 32px;
    color: white;
  }

  .tool-badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.15);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-left: auto;
  }

  .tool-featured-body {
    padding: 1.75rem var(--space-8) var(--space-8);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .tool-featured-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0;
    line-height: 1.3;
  }

  .tool-featured-desc {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .tool-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }

  .tool-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--brand-red);
    margin-top: auto;
    padding-top: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  .tool-link-arrow {
    transition: transform var(--duration-200) var(--ease);
  }

  .tool-featured:hover .tool-link-arrow {
    transform: translateX(4px);
  }

  /* ── Standard Card ── */
  .tool-standard {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: var(--surface-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: var(--space-8);
    position: relative;
    transition: box-shadow var(--duration-300) var(--ease),
      transform var(--duration-300) var(--ease);
  }

  .tool-standard:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .tool-standard::before {
    content: '';
    position: absolute;
    top: 0;
    left: var(--space-6);
    right: var(--space-6);
    height: 3px;
    background: linear-gradient(90deg, var(--brand-orange), var(--brand-red), transparent);
    border-radius: 0 0 3px 3px;
  }

  .tool-standard-icon {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--brand-orange) 10%, var(--surface-card));
    border-radius: var(--radius-md);
    margin-bottom: var(--space-5);
  }

  .standard-icon-svg {
    width: 26px;
    height: 26px;
    color: var(--brand-orange);
  }

  .tool-standard-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .tool-standard-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--text-heading);
    margin: 0;
    line-height: 1.3;
  }

  .tool-standard-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .tool-standard-arrow {
    font-size: var(--text-xl);
    color: var(--text-muted);
    align-self: flex-end;
    margin-top: var(--space-4);
    transition: transform var(--duration-200) var(--ease),
      color var(--duration-200) var(--ease);
  }

  .tool-standard:hover .tool-standard-arrow {
    color: var(--brand-red);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .page-tools {
      padding: 0.5rem 0 4rem;
    }

    .tools-bento {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .tool-featured-header {
      padding: var(--space-8) var(--space-6) var(--space-6);
    }

    .tool-featured-body {
      padding: var(--space-5) var(--space-6) var(--space-6);
    }

    .tool-standard {
      padding: var(--space-6);
    }

    .tool-standard::before {
      left: var(--space-4);
      right: var(--space-4);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tool-featured,
    .tool-standard {
      transition: none;
    }
    .tool-featured:hover,
    .tool-standard:hover {
      transform: none;
    }
    .tool-link-arrow,
    .tool-standard-arrow {
      transition: none;
    }
  }
</style>
