---
import FeatureCard from '@/components/ui/FeatureCard.astro';
import FeatureGrid from '@/components/ui/FeatureGrid.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const appUrl = 'https://herbs-app.rxdevman.com/';
const repoUrl = 'https://github.com/suradet-ps/herbs-app';
---

<BaseLayout title="Project: บัญชียาสมุนไพร รพ.สระโบสถ์">
    <div class="project-showcase">
        <header class="project-header">
            <h1>บัญชียาสมุนไพร รพ.สระโบสถ์</h1>
            <p class="subtitle">
                เว็บแอปพลิเคชันสำหรับค้นหาข้อมูลยาสมุนไพรในบัญชีที่สนับสนุนโดย
                สปสช. รวดเร็ว แม่นยำ และใช้งานง่ายบนมือถือ
            </p>

            <div class="button-group">
                <a
                  href={appUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cta-button launch-button"
                >
                    เปิดใช้งานระบบ
                </a>
                <a
                  href={repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="repo-link"
                >
                    ดู Source Code
                </a>
            </div>
        </header>

        <div class="screenshot-container">
            <img
              src="/images/tools/herbs-app.png"
              alt="Screenshot of Thai Herbal NHSO Support App"
              class="main-screenshot"
              onerror="this.style.display='none'"
            />
        </div>

        <div class="project-details">
            <h2>คุณสมบัติหลัก</h2>
            <FeatureGrid>
                <FeatureCard title="Google Sheets Backend" icon="table-cells">
                    ใช้ Google Sheets เป็นฐานข้อมูล
                    ทำให้เภสัชกรหรือเจ้าหน้าที่สามารถอัปเดตข้อมูลยา ราคา
                    หรือเงื่อนไขการเบิกจ่ายได้เองโดยไม่ต้องแก้โค้ด
                </FeatureCard>
                <FeatureCard title="ค้นหาแบบ Real-time" icon="magnifying-glass">
                    ระบบค้นหาทันทีที่พิมพ์ รองรับชื่อยา และการกรองตามหมวดหมู่
                    ช่วยให้หน้างานทำงานได้รวดเร็ว
                </FeatureCard>
                <FeatureCard
                  title="ข้อมูลการเบิกจ่ายครบถ้วน"
                  icon="currency-dollar"
                >
                    แสดงรายละเอียดที่สำคัญสำหรับการทำงาน เช่น ราคาจ่ายชดเชยของ
                    สปสช., จำนวนที่เบิกได้ต่อรอบ, และรหัส ICD10
                    สำหรับคีย์ข้อมูลให้ถูกต้อง
                </FeatureCard>
                <FeatureCard
                  title="Responsive Design"
                  icon="device-phone-mobile"
                >
                    ออกแบบด้วย Vue.js ให้แสดงผลสวยงามทั้งบน Desktop และ Mobile
                    เหมาะสำหรับการเปิดดูข้อมูลหน้างาน
                </FeatureCard>
            </FeatureGrid>

            <div class="tech-stack-section">
                <h2>Tech Stack</h2>
                <div class="stack-items">
                    <span class="stack-item">Vue.js 3</span>
                    <span class="stack-item">Vite</span>
                    <span class="stack-item">Google Apps Script</span>
                    <span class="stack-item">Google Sheets</span>
                    <span class="stack-item">CSS Variables</span>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>


