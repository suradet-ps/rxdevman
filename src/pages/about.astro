---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="About Me">

  <!-- ── Page Header ───────────────────────────────────── -->
  <section class="page-header">
    <div class="container page-header-inner">
      <p class="eyebrow">ABOUT</p>
      <h1 class="page-title">จากเภสัชกรสู่โปรแกรมเมอร์</h1>
    </div>
  </section>

  <!-- ── Content ───────────────────────────────────────── -->
  <section class="about-section">
    <div class="container about-grid">

      <!-- Left: Text -->
      <div class="text-content">
        <p>
          เส้นทางของผมเริ่มต้นที่เคาน์เตอร์จ่ายยาท่ามกลางใบสั่งยาและการดูแลผู้ป่วย
          มาวันนี้ผมเปลี่ยนมาสร้างสรรค์โซลูชันดิจิทัล เขียนโค้ดที่สะอาดตา
          และออกแบบประสบการณ์ผู้ใช้ที่เข้าใจง่าย
          นี่คือเรื่องราวการเดินทางของผมจากบทบาทเภสัชกรสู่การเป็นนักพัฒนาซอฟต์แวร์
        </p>
        <p>
          ผมคือเภสัชกรสุรเดช ประถมศักดิ์ ผู้สร้าง RxDev Man
          ด้วยความหลงใหลในตรรกะ การแก้ปัญหา และประสิทธิภาพ
          ซึ่งเป็นทักษะที่ได้ฝึกฝนจากงานสายสาธารณสุข
          ทำให้ผมได้ค้นพบเส้นทางใหม่ในการพัฒนาซอฟต์แวร์
          ผมทึ่งกับวิธีที่เทคโนโลยีสามารถแก้ปัญหาที่ซับซ้อนในวงกว้างได้
          และตัดสินใจที่จะกระโดดเข้ามาเรียนรู้อย่างเต็มตัว
        </p>
        <p>
          เว็บไซต์นี้เปรียบเสมือนคลังความรู้ส่วนตัวและบันทึกการเรียนรู้ที่ผมเปิดเผยสู่สาธารณะ
          ผมเขียนเกี่ยวกับหัวข้อต่างๆ ที่กำลังศึกษา ตั้งแต่ frontend frameworks
          อย่าง Astro และ Vue ไปจนถึงความท้าทายเฉพาะทางในซอฟต์แวร์โรงพยาบาลอย่าง
          HOSxP
          เป้าหมายของผมคือการสร้างความเข้าใจที่ลึกซึ้งยิ่งขึ้นผ่านการแบ่งปันความรู้ให้ผู้อื่น
          และเผยแพร่แหล่งข้อมูลที่เป็นประโยชน์ซึ่งผมได้ใช้ตลอดเส้นทางนี้
        </p>

        <h2 class="section-divider">ช่องทางการติดต่อ</h2>
        <p>
          ผมเปิดรับการพูดคุยเกี่ยวกับโปรเจกต์ใหม่ๆ แลกเปลี่ยนความรู้
          หรือเรื่องราวเกี่ยวกับเทคโนโลยีเสมอ อย่าลังเลที่จะติดต่อมานะครับ
        </p>

        <div class="social-links">
          <a
            href="https://github.com/suradet-ps/"
            target="_blank"
            rel="noopener noreferrer"
            class="social-pill"
          >
            <!-- GitHub icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.09.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
            </svg>
            GitHub
          </a>

          <a
            href="mailto:pharmacistsabot@gmail.com"
            class="social-pill"
          >
            <!-- Email icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
            อีเมล
          </a>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="image-content">
        <img
          src="/images/common/profile-placeholder.jpg"
          alt="A portrait of Sabot"
          class="profile-image"
        />
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* ── Page Header ────────────────────── */
  .page-header {
    background-color: var(--color-accent-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 4rem 0 4.5rem;
    text-align: center;
  }

  .page-header-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0;
  }

  .page-title {
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-near-black);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 0;
  }

  /* ── About Content ──────────────────── */
  .about-section {
    padding: 4.5rem 0 6rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Text */
  .text-content p {
    color: var(--color-text-secondary);
    font-size: 1.0625rem;   /* 17px */
    line-height: 1.8;
  }

  /* Section divider h2 */
  .section-divider {
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--color-near-black);
    border-left: 4px solid var(--color-brand-orange);
    padding-left: 1rem;
    margin-top: 2.5rem;
    margin-bottom: var(--space-4);
    line-height: 1.3;
  }

  /* Social pills */
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .social-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background-color: var(--color-card-bg);
    color: var(--color-text-primary);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    border-bottom: 3px solid var(--color-btn-border);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transition:
      transform 0.15s ease,
      border-color 0.15s ease,
      background-color 0.15s ease,
      color 0.15s ease;
  }

  .social-pill:hover {
    transform: translateY(-2px);
    border-color: var(--color-brand-orange);
    border-bottom-color: var(--color-btn-border);
    background-color: var(--color-accent-surface);
    color: var(--color-near-black);
  }

  .social-pill:focus-visible {
    outline: 2px solid var(--color-brand-orange);
    outline-offset: 3px;
  }

  /* Profile image */
  .image-content {
    position: sticky;
    top: 80px;  /* matches navbar height 56px + gap */
  }

  .profile-image {
    width: 100%;
    border-radius: var(--radius-lg);
    object-fit: cover;
    border: 1px solid var(--color-border);
    border-bottom: 3px solid var(--color-border);
  }

  /* ── Responsive ─────────────────────── */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .image-content {
      order: -1;
      position: static;
      max-width: 260px;
      margin: 0 auto;
    }
  }

  @media (max-width: 480px) {
    .page-header {
      padding: 3rem 0 3.5rem;
    }

    .about-section {
      padding: 3rem 0 4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .social-pill {
      transition: none;
    }
    .social-pill:hover {
      transform: none;
    }
  }
</style>
