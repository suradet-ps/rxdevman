---
import BlogPostCard from '@/components/blog/BlogPostCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllBlogPosts } from '@/lib/blog';

const allPosts = await getAllBlogPosts();
const invsPosts = allPosts
  .filter(post => post.data.category === 'INVS')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="INVS Resources">
  <div class="container invs-container">
    <h1 class="invs-title">INVS</h1>
    <p class="invs-subtitle">
      พื้นที่สำหรับรวบรวมเครื่องมือ คู่มือ และบันทึกต่าง ๆ ที่เกี่ยวข้องกับโปรแกรมจัดซื้อและบริหารคลังเวชภัณฑ์ยา INVS
    </p>

    {invsPosts.length > 0
? (
      <div class="post-grid">
        {invsPosts.map(post => (
          <BlogPostCard post={post} />
        ))}
      </div>
    )
: (
      <div class="status-box" role="status" aria-live="polite">
        <p>Coming Soon</p>
      </div>
    )}

    <a href="/blog" class="cta-button">Back to Blog</a>
  </div>
</BaseLayout>

<style>
  .invs-container { text-align: center; padding-bottom: var(--space-12); }
  .invs-title {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    margin-bottom: var(--space-2);
  }
  .invs-subtitle {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin-bottom: var(--space-8);
  }
</style>
