---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="INVS Resources">
  <div class="container section-header">
    <h1>INVS</h1>
    <p>
      A collection of tools, guides, and notes related to the INVS pharmaceutical procurement and inventory management system.
    </p>
  </div>

  <div class="container" style="display: flex; justify-content: center;">
    <div class="coming-soon">
      <span class="coming-soon-badge">Coming Soon</span>
      <p class="coming-soon-text">Tools and resources for INVS are on their way.</p>
    </div>
  </div>
</BaseLayout>
